# ================================================================
# 🔮 한국형 만세력 운세 시스템 - 환경 변수 설정 템플릿
# ================================================================
# 이 파일을 복사하여 .env 파일로 사용하세요:
#   cp .env.example .env
# 그 후 각 값을 실제 환경에 맞게 수정하세요.
# ================================================================

# ─── 데이터베이스 (MySQL) ────────────────────────────────────────
MYSQL_ROOT_PASSWORD=root_fortune_2025!
MYSQL_PASSWORD=fortune_secure_2025!

# ─── Redis ──────────────────────────────────────────────────────
REDIS_PASSWORD=

# ─── Spring Boot 애플리케이션 ────────────────────────────────────
SPRING_PROFILES_ACTIVE=docker

# ─── AI 기능 (선택) ──────────────────────────────────────────────
# AI 기능을 사용하려면 AI_ENABLED=true 로 설정하고 API 키를 입력하세요.
AI_ENABLED=false
OPENAI_API_KEY=

# ─── 텔레그램 봇 (선택) ──────────────────────────────────────────
# 텔레그램 알림을 사용하려면 아래 값을 설정하세요.
# 봇 생성: https://t.me/BotFather → /newbot
TELEGRAM_BOT_TOKEN=
TELEGRAM_CHAT_ID=

# ─── 이메일 발송 (선택) ──────────────────────────────────────────
MAIL_HOST=smtp.gmail.com
MAIL_PORT=587
MAIL_USERNAME=
MAIL_PASSWORD=
MAIL_FROM=noreply@example.com

# ─── 모니터링 ────────────────────────────────────────────────────
GRAFANA_PASSWORD=admin123

# ─── OpenTelemetry 추적 (선택) ───────────────────────────────────
# Jaeger, Grafana Tempo 등 OTLP 수집기를 사용하는 경우에만 설정
# OTEL_EXPORTER_OTLP_ENDPOINT=http://otel-collector:4318/v1/traces
# OTEL_SAMPLING_PROBABILITY=0.1
