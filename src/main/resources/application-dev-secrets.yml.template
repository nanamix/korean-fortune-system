# ==============================================
# 개발 환경 민감 정보 설정 템플릿
# ==============================================
# ⚠️ 이 파일을 application-dev-secrets.yml로 복사한 후 실제 값으로 변경하세요.
# ⚠️ application-dev-secrets.yml는 .gitignore에 추가되어 Git에 커밋되지 않습니다.
# 
# 사용 방법:
# 1. 이 파일을 application-dev-secrets.yml로 복사
# 2. 아래 값들을 실제 값으로 변경
# 3. 애플리케이션 재시작

spring:
  mail:
    username: your-email@gmail.com  # 실제 Gmail 주소로 변경
    password: your-app-password     # Gmail 앱 비밀번호로 변경

app:
  fortune:
    telegram:
      bot-token: your-telegram-bot-token  # 텔레그램 봇 토큰으로 변경
      chat-id: your-telegram-chat-id      # 텔레그램 채팅 ID로 변경

# 또는 환경변수로 설정:
# export EMAIL_USERNAME=your-email@gmail.com
# export EMAIL_PASSWORD=your-app-password
# export TELEGRAM_BOT_TOKEN=your-telegram-bot-token
# export TELEGRAM_CHAT_ID=your-telegram-chat-id 